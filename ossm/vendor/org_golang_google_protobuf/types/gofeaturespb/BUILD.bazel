load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "gofeaturespb",
    srcs = ["go_features.pb.go"],
    importpath = "google.golang.org/protobuf/types/gofeaturespb",
    visibility = ["//visibility:public"],
    deps = [
        "//reflect/protoreflect",
        "//runtime/protoimpl",
        "//types/descriptorpb",
