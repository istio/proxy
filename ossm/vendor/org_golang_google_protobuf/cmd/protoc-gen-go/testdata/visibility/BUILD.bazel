load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "visibility",
    srcs = ["visibility.pb.go"],
    importpath = "google.golang.org/protobuf/cmd/protoc-gen-go/testdata/visibility",
    visibility = ["//visibility:public"],
    deps = [
        "//reflect/protoreflect",
        "//runtime/protoimpl",
    ],
)

alias(
    name = "go_default_library",
    actual = ":visibility",
    visibility = ["//visibility:public"],
)
