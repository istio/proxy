load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "mixed",
    srcs = ["mixed.pb.go"],
    importpath = "google.golang.org/protobuf/internal/testprotos/mixed",
    visibility = ["//:__subpackages__"],
    deps = [
        "//reflect/protoreflect",
        "//runtime/protoimpl",
        "//types/gofeaturespb",
