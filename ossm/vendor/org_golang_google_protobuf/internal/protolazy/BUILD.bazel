load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "protolazy",
    srcs = [
        "bufferreader.go",
        "lazy.go",
        "pointer_unsafe.go",
    ],
    importpath = "google.golang.org/protobuf/internal/protolazy",
    visibility = ["//:__subpackages__"],
    deps = [
        "//encoding/protowire",
        "//runtime/protoiface",
    ],
)

alias(
    name = "go_default_library",
    actual = ":protolazy",
    visibility = ["//:__subpackages__"],
)
