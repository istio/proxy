load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "windows",
    srcs = [
        "aliases.go",
        "dll_windows.go",
        "env_windows.go",
        "eventlog.go",
        "exec_windows.go",
        "memory_windows.go",
        "race.go",
        "race0.go",
        "security_windows.go",
        "service.go",
        "setupapi_windows.go",
        "str.go",
        "syscall.go",
        "syscall_windows.go",
        "types_windows.go",
        "types_windows_386.go",
        "types_windows_amd64.go",
        "types_windows_arm.go",
        "types_windows_arm64.go",
        "zerrors_windows.go",
        "zknownfolderids_windows.go",
        "zsyscall_windows.go",
    ],
    importpath = "golang.org/x/sys/windows",
    visibility = ["//visibility:public"],
)

alias(
    name = "go_default_library",
    actual = ":windows",
    visibility = ["//visibility:public"],
)

go_test(
    name = "windows_test",
    srcs = [
        "env_windows_test.go",
        "syscall_test.go",
        "syscall_windows_test.go",
    ],
    data = glob(["testdata/**"]),
    deps = select({
        "@io_bazel_rules_go//go/platform:windows": [
            ":windows",
        ],
        "//conditions:default": [],
    }),
)
