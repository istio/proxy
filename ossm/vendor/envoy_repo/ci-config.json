{
  "agent-ubuntu": "ubuntu-24.04",
  "build-image": {
    "repo": "docker.io/envoyproxy/envoy-build",
    "repo-gcr": "gcr.io/envoy-ci/envoy-build",
    "sha": "20656853fae51927cda557e7af80ccff175f5de6f84bd0f092cd8672b2a6e0fe",
    "sha-ci": "20656853fae51927cda557e7af80ccff175f5de6f84bd0f092cd8672b2a6e0fe",
    "sha-devtools": "6e7a82d4f1ba040f4ebef0c1aae00cdbd205ff7a1284c20cc20984fdfa4a91d8",
    "sha-docker": "85b6c3e76f093d9c9d10a968b5615cc8d82f38d7aef311100d542e4d640f5a74",
    "sha-gcc": "439e870260c1599646d05b8b5d3bf1b6dd585c2e3cdac78dcb9f4081564c27fd",
    "sha-mobile": "bd1338a8951376211e4f4f6ff3171675670c4c582b0966f1d247abd3ba6a8a67",
    "sha-worker": "25a68eff24b7414a346977d545687b87851d1c5746c466798050fa12fc5d0686",
    "mobile-sha": "bd1338a8951376211e4f4f6ff3171675670c4c582b0966f1d247abd3ba6a8a67",
    "tag": "86873047235e9b8232df989a5999b9bebf9db69c"
  },
  "config": {
    "envoy": {
      "icon": "[![](https://avatars.githubusercontent.com/u/30125649?s=24&v=4)](#)"
    }
  },
  "checks": {
    "checks": {
      "name": "Envoy/Checks",
      "on-run": [
        "check-build",
        "check-build-openssl",
        "check-coverage",
        "check-runtime",
        "check-san"
      ],
      "required": true
    },
    "macos": {
      "name": "Envoy/macOS",
      "required": true,
      "on-run": [
        "build-macos"
      ]
    },
    "prechecks": {
      "name": "Envoy/Prechecks",
      "on-run": [
        "precheck-deps",
        "precheck-external",
        "precheck-format",
        "precheck-publish",
        "precheck-publish-config"
      ],
      "required": true,
      "advice": {
        "general": "### Ensuring your commits are signed off\n\nYou can set up DCO using Envoy's git hooks.\n\n### Git hooks\n\nTo set this up, do the following:\n\n  ```console\n  $ ./support/bootstrap\n  ```\n\n  If you only want the DCO check you can do the following to disable the\n  other hooks\n\n  ```console\n  $ echo NO_VERIFY=1 > .env\n  ```\n",
        "deps": "### Advice on updating dependencies\n\nGeneral information about Envoy's depdendencies [can be found here](https://github.com/envoyproxy/envoy/blob/main/DEPENDENCY_POLICY.md)\n",
        "format": "### Advice on correct formatting\n\nEnvoy ensures a minimum standard for all files in the repository.\n\nYou are strongly advised to heed the following CI notice:\n\n  ```console\n    Please fix your editor to ensure:\n\n      - no trailing whitespace\n      - no preceding mixed tabs/spaces\n      - all files end with a newline\n  ```\n"
      }
    },
    "publish": {
      "name": "Envoy/Publish and verify",
      "on-run": [
        "release",
        "verify"
      ],
      "required": true
    }
  },
  "run": {
    "build-macos": {
      "paths": [
        ".bazelrc",
        ".bazelversion",
        ".github/config.yml",
        "api/**/*",
        "bazel/**/*",
        "ci/**/*",
        "configs/**/*",
        "contrib/**/*",
        "envoy/**/*",
        "source/**/*",
        "test/**/*"
      ]
    },
    "check-build": {
      "paths": [
        "**/*"
      ]
    },
    "check-build-openssl": {
      "paths": [
        "**/*"
      ]
    },
    "check-coverage": {
      "paths": [
        "**/*"
      ]
    },
    "check-runtime": {
      "paths": [
        "source/server/cgroup_cpu_util.*",
        "test/server/*cgroup*"
      ],
      "push": "paths"
    },
    "check-san": {
      "paths": [
        "**/*"
      ]
    },
    "precheck-deps": {
      "paths": [
        ".bazelrc",
        ".bazelversion",
        ".github/config.yml",
        ".github/dependabot.yml",
        "bazel/BUILD",
        "tools/dependency/*",
        "**/*.bzl",
        "**/requirements.txt",
        "**/go.mod",
        "**/Dockerfile*"
      ],
      "push": "paths"
    },
    "precheck-external": {
      "paths": [
        "**/*"
      ]
    },
    "precheck-format": {
      "paths": [
        "**/*"
      ]
    },
    "precheck-publish": {
      "paths": [
        "**/*"
      ]
    },
    "precheck-publish-config": {
      "paths": [
        "**/*"
      ]
    },
    "release": {
      "paths": [
        ".bazelrc",
        ".bazelversion",
        ".github/config.yml",
        "api/**/*",
        "bazel/**/*",
        "ci/**/*",
        "contrib/**/*",
        "distribution/**/*",
        "envoy/**/*",
        "examples/**/*",
        "source/**/*",
        "tools/**/*",
        "VERSION.txt"
      ]
    },
    "verify": {
      "paths": [
        ".bazelrc",
        ".bazelversion",
        ".github/config.yml",
        ".github/workflows/envoy-publish.yml",
        ".github/workflows/_publish_verify.yml",
        "api/**/*",
        "bazel/**/*",
        "ci/**/*",
        "contrib/**/*",
        "distribution/**/*",
        "envoy/**/*",
        "examples/**/*",
        "source/**/*",
        "tools/**/*",
        "VERSION.txt"
      ],
      "push": "paths"
    }
  },
  "tables": {
    "env": {
      "collapse": true,
      "title": "Environment",
      "table-title": "Request variables",
      "filter": ".request\n| del(.[\"build-image\" as $prefix | keys[] | select(startswith($prefix))])\n| del(.[\"version\" as $prefix | keys[] | select(startswith($prefix))])\n| .actor  = \"<img src=\\\"\\(.actor.icon)\\\" alt=\\\"\\(.actor.name)\\\" width=\\\"18\\\" height=\\\"18\\\">  @\\(.actor.name)\"\n"
    },
    "build-image": {
      "collapse": true,
      "title": "Build image",
      "table-title": "Container image/s (as used in this CI run)",
      "filter": "\"https://hub.docker.com/r/envoyproxy/envoy-build/tags?page=1&name=\" as $dockerLink\n| .request[\"build-image\"]\n| del(.changed)\n| with_entries(\n    .value as $v\n    | ($v | split(\":\") | .[1] | split(\"@\") | .[0]) as $tag\n    | .value = \"[\\($v | split(\"@\") | .[0])](\\($dockerLink)\\($tag))\")\n"
    },
    "build-image-current": {
      "collapse": true,
      "title": "Build image (current)",
      "table-title": "Current or previous container image",
      "filter": "\"https://hub.docker.com/r/envoyproxy/envoy-build/tags?page=1&name=\" as $dockerLink\n| if .request[\"build-image\"].changed then\n    .request[\"build-image-current\"]\n    | with_entries(\n        .value as $v\n        | ($v | split(\":\") | .[1] | split(\"@\") | .[0]) as $tag\n        | .value = \"[\\($v | split(\"@\") | .[0])](\\($dockerLink)\\($tag))\")\n  else {} end\n"
    },
    "version": {
      "collapse": true,
      "title": "Version",
      "table-title": "Envoy version (as used in this CI run)",
      "filter": ".request.version\n| del(.changed)\n"
    },
    "version-current": {
      "collapse": true,
      "title": "Version (current)",
      "table-title": "Current or previous version",
      "filter": "if .request.version.changed then\n  .request[\"version-current\"]\nelse\n  {}\nend\n"
    }
  }
}
