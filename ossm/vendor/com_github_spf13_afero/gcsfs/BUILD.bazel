load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "gcsfs",
    srcs = [
        "errors.go",
        "file.go",
        "file_info.go",
        "file_resource.go",
        "fs.go",
        "gcs.go",
        "gcs_mocks.go",
    ],
    importpath = "github.com/spf13/afero/gcsfs",
    visibility = ["//visibility:public"],
    deps = [
        "//:afero",
        "@com_github_googleapis_google_cloud_go_testing//storage/stiface:go_default_library",
