go_test(
    name = "gcsfs_test",
    srcs = ["gcs_test.go"],
    embed = [":gcsfs"],
    deps = [
        "//:afero",
        "@com_github_googleapis_google_cloud_go_testing//storage/stiface:go_default_library",
