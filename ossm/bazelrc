# Common build flags

build --verbose_failures

# Toolchain configuration
build --repo_env=BAZEL_USE_HOST_SYSROOT=True
build --repo_env=BAZEL_LLVM_PATH=/usr
build --config=clang-local
build --action_env=Clang_DIR=/usr/lib64/llvm21
build --cxxopt=-Wno-nullability-completeness

build --host_force_python=PY3
build --extra_toolchains=@rules_python//python:autodetecting_toolchain

build --extra_toolchains=@local_jdk//:all
build --tool_java_runtime_version=local_jdk

# OpenSSL configuration
common --config=openssl

# Test flags
build --test_env=ENVOY_IP_TEST_VERSIONS=v4only
build --test_env=HEAPCHECK=minimal
build --test_output=all

# Arch-specific build flags, triggered with --config=$ARCH in bazel build command
build:x86_64 --define=DUMMY=dummy
build:s390x --cxxopt='-includeoptional' --copt=-Wno-error=type-limits --copt=-Wno-error=uninitialized --copt=-fno-builtin-strlen --action_env=BAZEL_LINKLIBS=-lstdc++
build:ppc --action_env=BAZEL_LINKLIBS=-lstdc++
build:aarch64 --define=DUMMY=dummy

# Colored ouput messes with some of the logging systems in CI, so we disable that.
build:ci-config --color=no
build:ci-config --show_progress_rate_limit=10

