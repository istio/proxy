# common --action_env=CC=/usr/bin/clang
# common --action_env=CXX=/usr/bin/clang++
# # Use system make to avoid bootstrapping GNU Make with custom header flags
# common --action_env=MAKE=/usr/bin/make

# Import vendor flags
import %workspace%/ossm/bazelrc-vendor
